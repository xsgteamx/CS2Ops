PANEL_PORT=8080
PANEL_BIND_HOST=127.0.0.1

# Panel Login (Basic Auth)
PANEL_USER=admin
PANEL_PASS=change_me
PANEL_SESSION_SECRET=change_me_long_random_session_secret
PANEL_SESSION_TTL_MS=43200000
PANEL_RATE_LIMIT_WINDOW_MS=900000
PANEL_RATE_LIMIT_MAX=3000

# CS2 RCON target
CS2_HOST=127.0.0.1
CS2_PORT=27015
CS2_RCON_PASSWORD=change_me

# Optional: allow only these maps as "one-click"
STANDARD_MAPS=de_dust2,de_mirage,de_inferno,de_nuke,de_ancient,de_anubis,de_vertigo

# Log source mode:
# docker = old docker logs mode
# http   = CS2 logaddress_add_http receiver
# none   = disable live logs
LOG_SOURCE=http
LOG_LINES=200
LOG_TTL_MS=3600000

# Docker log mode, only used when LOG_SOURCE=docker
DOCKER_CONTAINER=cs2-dedicated

# HTTP remote log mode, only used when LOG_SOURCE=http
LOG_HTTP_BIND_HOST=0.0.0.0
LOG_HTTP_PORT=27500
LOG_HTTP_PATH=/cs2log
LOG_HTTP_SECRET=change_me_long_random_token
LOG_HTTP_PUBLIC_URL=http://10.6.0.2:27500/cs2log/change_me_long_random_token
LOG_HTTP_MAX_BODY=64kb

# Optional. Empty means allow all.
# Examples:
# LOG_HTTP_ALLOW_IPS=192.168.50.101,10.6.0.1
LOG_HTTP_ALLOW_IPS=

# If true, panel can execute RCON commands to register HTTP log address.
LOG_HTTP_RCON_REGISTER=true

AUTO_TTL_MS=600000
AUTO_MAX_ITEMS=80000
